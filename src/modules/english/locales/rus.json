    "firstSection": {
        "title": "АРТИКЛЬ (ARTICLE)",
        "content": [
            {
                "title": "НУЛЕВОЙ АРТИКЛЬ (ZERO ARTICLE)",
                "description": "Используется, когда мы говорим о вещах в общем смысле или с использованием конкретных категорий.",
                "content": [
                    {
                        "subtitle": "Существительные во множественном числе и неисчисляемые",
                        "description": "Пример: Cats are independent."
                    },
                    {
                        "subtitle": "Имена собственные",
                        "description": "Пример: He lives in London."
                    },
                    {
                        "subtitle": "С названиями игр, видов спорта и учебных предметов или с некоторыми словами и выражениями: work, home, TV, to have breakfast/lunch/dinner.",
                        "description": "Пример: I go to work by bus."
                    }
                ]
            },
            {
                "title": "ОПРЕДЕЛЕННЫЙ АРТИКЛЬ: THE",
                "description": "Используется с исчисляемыми (единственное и множественное число) и неисчисляемыми существительными, когда и говорящий, и слушающий точно знают, о чем идет речь.",
                "content": [
                    {
                        "subtitle": "Конкретные предметы",
                        "description": "Пример: Look at the moon."
                    },
                    {
                        "subtitle": "Повторное упоминание",
                        "description": "Пример: I saw a movie. The movie was long."
                    },
                    {
                        "subtitle": "Превосходная степень",
                        "description": "Пример: He is the best student."
                    }
                ]
            },
            {
                "title": "НЕОПРЕДЕЛЕННЫЙ АРТИКЛЬ: A / AN",
                "description": "Используется со счетными существительными единственного числа при первом упоминании чего-либо или при разговоре о вещах в целом.",
                "content": [
                    {
                        "subtitle": "A - Перед словами, начинающимися с согласного звука.",
                        "description": "Пример: a book, a horse"
                    },
                    {
                        "subtitle": "An - Перед словами, начинающимися с гласного звука.",
                        "description": "Пример:  an apple, an hour"
                    }
                ]
            }
        ]
    },
