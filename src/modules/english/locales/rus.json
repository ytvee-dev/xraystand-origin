            },
            {
                "title": "НАРЕЧИЯ ОПИСЫВАЮТ ПРИЛАГАТЕЛЬНЫЕ (ADVERBS DESCRIBE ADJECTIVES)",
                "description": "Пример: Mount Ranier is quite tall."
            },
            {
                "title": "НАРЕЧИЯ ОПИСЫВАЮТ НАРЕЧИЯ (ADVERBS DESCRIBE ADVERBS) ",
                "description": "Пример: The hotel is almost fully booked."
            }
        ]
    },
