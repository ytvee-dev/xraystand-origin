    "fourthSection": {
        "title": "ГЛАГОЛ (VERB)",
        "description": "Глагол — это самостоятельная часть речи, которая выражает действие предмета или лица или их состояние.",
        "content": [
            {
                "title": "ГЛАГОЛЫ ДЕЙСТВИЯ (ACTION VERBS):",
                "subtitle": "Показывают физическое или умственное действие",
                "description": "Пример: She runs every morning."
            },
            {
                "title": "ГЛАГОЛЫ СОСТОЯНИЯ (STATIVE VERBS):",
                "subtitle": "Описывают состояние или чувство ",
                "description": "Пример: He knows the correct answer. He still believes that story."
            },
            {
                "title": "ПРАВИЛЬНЫЕ ГЛАГОЛЫ (REGULAR VERBS):",
                "subtitle": "Дополняются окончанием “-ed” в прошедшем времени",
                "description": "Пример: work → worked → worked"
            },
            {
                "title": "НЕПРАВИЛЬНЫЕ ГЛАГОЛЫ (IRREGULAR VERBS):",
                "subtitle": "Изменяют форму в прошедшем времени",
                "description": "Пример: go → went → gone"
            },
            {
                "title": "СВЯЗУЮЩИЕ ГЛАГОЛЫ (LINKING VERBS):",
                "subtitle": "Связывает глагол для описания действия предмета",
                "description": "Пример: She seems nervous"
            },
            {
                "title": "ПЕРЕХОДНЫЕ ГЛАГОЛЫ (TRANSITIVE VERBS):",
                "subtitle": "Требуют прямого дополнения",
                "description": "Пример: He reads a book."
            },
            {
                "title": "НЕПЕРЕХОДНЫЕ ГЛАГОЛЫ (INTRANSITIVE VERBS):",
                "subtitle": "Не требуют прямого дополнения",
                "description": "Пример: They arrived late."
            }
        ]
    },
    "fifthSection": {
        "title": "ВРЕМЕНА ГЛАГОЛОВ (TENSES)",
        "description": "Времена глаголов — это формы глаголов, которые показывают, когда происходит действие или состояние (прошлое, настоящее, будущее) и предоставляют подробную информацию о его продолжительности или завершении.",
        "content": [
            {
                "title": "ОСНОВНЫЕ ВРЕМЕНА",
                "content": [
                    {
                        "title": "Прошедшее (Past):",
                        "subtitle": "Произошло до текущего времени ",
                        "description": "Пример: walked, was eating."
                    },
                    {
                        "title": "Настоящее (Present):",
                        "subtitle": "Происходит сейчас или обычно (периодически)",
                        "description": "Пример: walks, is eating"
                    },
                    {
                        "title": "Будущее (Future):",
                        "subtitle": "Произойдет после текущего времени ",
                        "description": "Пример: will walk, will be eating"
                    }
                ]
            },
            {
                "title": "АСПЕКТЫ (ВОСПРИЯТИЕ ВРЕМЕНИ)",
                "description": "Они сочетаются с основными временами, чтобы добавить дополнить продолжительность или завершенность.",
                "content": [
                    {
                        "title": "Simple:",
                        "subtitle": "Факт, привычка",
                        "description": "Пример: He runs"
                    },
                    {
                        "title": "Continuous (Progressive):",
                        "subtitle": "Происходящее действие, процесс",
                        "description": "Пример: He is running"
                    },
                    {
                        "title": "Perfect:",
                        "subtitle": "Завершенное действие, часто к определенному моменту во времени",
                        "description": "Пример: He has run"
                    },
                    {
                        "title": "Perfect Continuous:",
                        "subtitle": "Действие началось в прошлом и продолжается или только что завершилось",
                        "description": "Пример: He has been running"
                    }
                ]
            }
        ]
    },
    "sixthSection": {
        "title": "12 ОСНОВНЫХ ВРЕМЕННЫХ ФОРМ",
        "description": "Создаются сочетанием времён с аспектами",
        "content": [
            {
                "title": "PAST",
